" Filetype
syntax enable

colorscheme catppuccin_latte

" Mouse
set mouse=a

" Wild
set wildoptions=pum " Pop-up Menu
set wildignorecase  " Case insensitive

" Linhas
set number
set relativenumber

" Pesquisa
set hlsearch
set incsearch
set ignorecase

" Tab
set expandtab
set autoindent
set shiftwidth=4 " Quantidade de Espaços ao digitar <Tab>
set tabstop=4
